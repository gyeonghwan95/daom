{
  "name": "daom",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/sync-favicon.mjs && next dev",
    "prebuild": "node scripts/sync-favicon.mjs && node scripts/fetch-naver-blog.mjs && node scripts/fetch-naver-place-reviews.mjs && node scripts/generate-rss.mjs && node scripts/validate-seo.mjs",
    "fetch:naver-blog": "node scripts/fetch-naver-blog.mjs",
    "fetch:naver-reviews": "node scripts/fetch-naver-place-reviews.mjs",
    "build": "node scripts/build-static.mjs",
    "build:server": "next build",
    "build:static": "npm run build",
    "start": "next start",
    "lint": "eslint",
    "preview": "npx --yes serve@14 out -p 3000"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.9",
    "framer-motion": "^12.40.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.9",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "swiper": "^12.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mdx": "^2.0.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
