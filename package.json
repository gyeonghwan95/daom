{
  "name": "daom",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/sync-favicon.mjs && next dev",
    "prebuild": "node scripts/sync-favicon.mjs && node scripts/fetch-naver-place-reviews.mjs && node scripts/generate-rss.mjs && node scripts/validate-seo.mjs && node scripts/validate-seo-intent-db.mjs && node scripts/generate-seo-landing-manifest.mjs && node scripts/validate-page-data.mjs && node scripts/generate-seo-pages.mjs && npm run build:search",
    "fetch:naver-blog": "node scripts/fetch-naver-blog.mjs",
    "fetch:naver-reviews": "node scripts/fetch-naver-place-reviews.mjs",
    "build": "node scripts/build-static.mjs",
    "build:server": "next build",
    "build:static": "npm run build",
    "start": "next start",
    "lint": "eslint",
    "validate:page-data": "node scripts/validate-page-data.mjs",
    "generate:seo-pages": "node scripts/generate-seo-pages.mjs",
    "check:routes": "node scripts/check-routes.mjs",
    "check:seo": "node scripts/check-seo.mjs",
    "check:diagnosis": "node scripts/check-diagnosis-pages.mjs",
    "build:search": "npx --yes tsx scripts/build-search-index.ts",
    "check:search": "npx --yes tsx scripts/check-search-index.ts",
    "check:lecture-history": "npx --yes tsx scripts/check-lecture-history.ts",
    "check:business-scope": "npx --yes tsx scripts/check-business-scope.ts",
    "audit:business-pages": "npx --yes tsx scripts/audit-business-pages.ts",
    "audit:real-estate-intents": "npx --yes tsx scripts/audit-real-estate-intents.ts",
    "check:route-duplicates": "npx --yes tsx scripts/check-route-duplicates.ts",
    "check:content-similarity": "npx --yes tsx scripts/check-content-similarity.ts",
    "check:metadata-duplicates": "npx --yes tsx scripts/check-metadata-duplicates.ts",
    "check:internal-links": "npx --yes tsx scripts/check-internal-links.ts",
    "check:thin-pages": "npx --yes tsx scripts/check-thin-pages.ts",
    "audit:real-estate": "npm run audit:real-estate-intents && npm run check:route-duplicates && npm run check:metadata-duplicates && npm run check:thin-pages && npm run check:content-similarity && npm run check:internal-links",
    "indexnow": "node scripts/submit-indexnow.mjs",
    "indexnow:dry": "node scripts/submit-indexnow.mjs --dry-run",
    "indexnow:deploy": "node scripts/submit-indexnow.mjs --wait-for-key --soft --retries=30 --retry-delay=20",
    "verify": "npm run build && npm run check:diagnosis",
    "preview": "npx --yes serve@14 out -p 3000"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.9",
    "framer-motion": "^12.40.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.9",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "swiper": "^12.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mdx": "^2.0.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
