# 사이트 기본 URL (SEO canonical, Open Graph, sitemap, RSS 등)
NEXT_PUBLIC_SITE_URL=https://daom-law.com

# ── 검색엔진 소유권 확인 (선택) ──
# Google Search Console → HTML 태그 값
GOOGLE_SITE_VERIFICATION=
# Naver Search Advisor → 소유확인 meta content 값
NAVER_SITE_VERIFICATION=

# 상담 연락처 (미설정 시 아래 기본값 사용)
# NEXT_PUBLIC_PHONE=070-4172-8056
# NEXT_PUBLIC_KAKAO_CHANNEL=http://pf.kakao.com/_Bvhxnn/chat
# NEXT_PUBLIC_NAVER_TALK=https://talk.naver.com/ct/w661kd4
NEXT_PUBLIC_PHONE=
NEXT_PUBLIC_KAKAO_CHANNEL=
NEXT_PUBLIC_NAVER_TALK=
# 하위 호환 (NAVER_TALK 미설정 시 사용)
NEXT_PUBLIC_NAVER_BOOKING=

# 온라인 문의 양식 (외부 링크 — 사이트에 개인정보 저장 안 함)
# Google Forms, Tally, 네이버폼 URL 중 하나 이상 설정
NEXT_PUBLIC_INQUIRY_FORM_GOOGLE=
NEXT_PUBLIC_INQUIRY_FORM_TALLY=
NEXT_PUBLIC_INQUIRY_FORM_NAVER=
# 기본으로 열 문의 양식: google | tally | naver (미설정 시 첫 번째 항목)
NEXT_PUBLIC_INQUIRY_FORM_PRIMARY=google
# 하위 호환용 단일 URL (위 항목이 없을 때만 사용)
NEXT_PUBLIC_INQUIRY_FORM_URL=
